{
  "$schema": "https://json.schemastore.org/package",
  "name": "goal",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "biome:ci": "bunx biome ci .",
    "biome:check": "bunx biome check .",
    "biome:fix": "bunx biome check . --write",
    "test:apps": "bun run test:packages && bun test ./apps --jsx-import-source hono/jsx",
    "test:packages": "bun test ./packages",
    "test:all": "bun run test:apps",
    "typecheck": "bunx tsc -b --noEmit"
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "version": "1.0.0"
}
